# Database Configuration
# For Neon PostgreSQL, use: postgresql://user:password@hostname.neon.tech/database
# For local PostgreSQL: postgresql://postgres:password@localhost:5432/collab_gui
DATABASE_URL=postgresql://user:password@localhost:5432/collab_gui

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=dev-secret-key-change-in-production

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000
